function _deleteEmptyRows() {
    var scriptProperties = PropertiesService.getScriptProperties();
    var counter = scriptProperties.getProperty("adhoc");

    // Initialize counter if it doesn't exist
    if (counter === null) {
        counter = 2;
    } else {
        counter = parseInt(counter); // Parse to integer if it exists
    }

    // Start of deletion
    var sheets = SpreadsheetApp.getActive().getSheets();
    for (counter; counter < sheets.length; counter++) {
        var sheet = sheets[counter]
        var lastRow = sheet.getLastRow();

        //console.log(`MaxCols=${sheet.getMaxColumns()}`)
        if (sheet.getMaxColumns() - 14 > 0) {
            sheet.deleteColumns(14, sheet.getMaxColumns() - 14)
        }

        var emptyRowLength = sheet.getMaxRows() - lastRow
        console.log(`Deleting empty rows on (${counter})${sheet.getSheetName()}: ${lastRow + 1}-${emptyRowLength}`)
        if (emptyRowLength == 0) {
            console.log(`Skipping due to 0 empty rows`)
        } else {
            sheet.deleteRows(lastRow + 1, emptyRowLength)
        }

        scriptProperties.setProperty("adhoc", counter.toString()); // Save back as string
    }
}
