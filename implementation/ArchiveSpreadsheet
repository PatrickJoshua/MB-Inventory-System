function _test() {
    const ss = SpreadsheetApp.getActive();
    ss.getSheets().slice(-500, -1).filter(s => s.getSheetName().endsWith(" 0") || s.getSheetName().endsWith(" 1") || s.getSheetName().endsWith(" 2") || s.getSheetName().endsWith(" 3") || s.getSheetName().endsWith(" 4") || s.getSheetName().endsWith(" 5") || s.getSheetName().endsWith(" 6") || s.getSheetName().endsWith(" 7") || s.getSheetName().endsWith(" 8") || s.getSheetName().endsWith(" 9")).forEach(s => {
        if (s.getSheetName() != "Sheet1") {
            console.log(`Deleting sheet: ${s.getSheetName()}`)
            ss.deleteSheet(s)
        }
    })
    return
    //let s = ss.getActiveSheet();
    //console.log(s.getIndex() + " " + ss.getSheets().length); return
    const propServ = PropertiesService.getScriptProperties();

    const sheets = ss.getSheets()
    for (i = parseInt(propServ.getProperty("adhoc")); i > 2; i--) {
        console.log(`Rasterizing ${sheets[i].getSheetName()}`)
        const rg = sheets[i].getRange("A1:AH" + sheets[i].getLastRow())
        rg.setValues(rg.getValues())
        propServ.setProperty("adhoc", i - 1)
    }
}

